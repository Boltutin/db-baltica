<Window x:Class="BaltikaApp.Wpf.ShipmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Рейсы" Icon="pack://application:,,,/Assets/AppIcon.ico" Height="620" Width="1100"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel x:Name="FilterBar" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Судно:" VerticalAlignment="Center"/>
                <ComboBox x:Name="ShipsCombo" Width="230" Margin="8,0,16,0"
                          DisplayMemberPath="reg_number" SelectedValuePath="ship_id"/>
                <TextBlock Text="От:" VerticalAlignment="Center"/>
                <DatePicker x:Name="FromDate" Width="140" Margin="8,0,16,0"/>
                <TextBlock Text="До:" VerticalAlignment="Center"/>
                <DatePicker x:Name="ToDate" Width="140" Margin="8,0,16,0"/>
                <Button Content="Сбросить фильтры" Style="{StaticResource NeutralButton}" Width="150" Click="OnResetFilters"/>
            </StackPanel>
            <StackPanel x:Name="ActionBar" Grid.Row="1" Orientation="Horizontal">
                <Button Content="Обновить" Style="{StaticResource AccentButton}"  Width="120" Margin="0,0,8,0" Click="OnRefresh"/>
                <Button x:Name="AddButton"    Content="Добавить" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,8,0" Click="OnAdd"/>
                <Button x:Name="EditButton"   Content="Изменить" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,8,0" Click="OnEdit"/>
                <Button x:Name="DeleteButton" Content="Удалить"  Style="{StaticResource DangerButton}"  Width="120" Click="OnDelete"/>
            </StackPanel>
        </Grid>
        <TextBlock x:Name="StatusText" DockPanel.Dock="Top" Margin="0,0,0,8" Foreground="{StaticResource NeutralBrush}" Text="Готово к работе."/>
        <DataGrid x:Name="Grid" SelectionMode="Single" MouseDoubleClick="OnGridDoubleClick"/>
    </DockPanel>
</Window>
