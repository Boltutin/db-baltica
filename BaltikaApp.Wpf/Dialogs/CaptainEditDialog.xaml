<Window x:Class="BaltikaApp.Wpf.Dialogs.CaptainEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Капитан"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="620" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="ФИО" VerticalAlignment="Center"/>
        <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Стаж (лет)" VerticalAlignment="Center"/>
        <TextBox x:Name="ExperienceBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="0"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,8,0" Click="OnSave"/>
            <Button Content="Отмена"    Style="{StaticResource NeutralButton}" Width="120" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
