<Window x:Class="BaltikaApp.Wpf.Dialogs.AddressEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Адрес"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="680" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Страна" VerticalAlignment="Center"/>
        <TextBox x:Name="CountryBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Регион" VerticalAlignment="Center"/>
        <TextBox x:Name="RegionBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Город" VerticalAlignment="Center"/>
        <TextBox x:Name="CityBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Улица" VerticalAlignment="Center"/>
        <TextBox x:Name="StreetBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Дом" VerticalAlignment="Center"/>
        <TextBox x:Name="BuildingBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,8,0" Click="OnSave"/>
            <Button Content="Отмена"    Style="{StaticResource NeutralButton}" Width="120" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
