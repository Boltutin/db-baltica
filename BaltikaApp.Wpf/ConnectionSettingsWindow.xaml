<Window x:Class="BaltikaApp.Wpf.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение к PostgreSQL"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="480" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                   Text="Укажите параметры подключения. Учётные записи baltika_reader и baltika_writer должны существовать на целевом сервере."
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Хост:" VerticalAlignment="Center"/>
        <TextBox x:Name="HostBox" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Порт:" VerticalAlignment="Center"/>
        <TextBox x:Name="PortBox" Grid.Row="2" Grid.Column="1" Height="28" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="База данных:" VerticalAlignment="Center"/>
        <TextBox x:Name="DbBox" Grid.Row="3" Grid.Column="1" Height="28" Margin="0,0,0,8"/>

        <StackPanel x:Name="ActionBarTop" Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,8">
            <Button Content="Проверить подключение"   Style="{StaticResource AccentButton}"  Width="170" Margin="0,0,8,0" Click="OnTest"/>
            <Button Content="Поднять локальный сервер" Style="{StaticResource NeutralButton}" Width="210" Click="OnStartLocal"/>
        </StackPanel>

        <GroupBox Header="Оформление" Grid.Row="5" Grid.ColumnSpan="2" Margin="0,0,0,8">
            <StackPanel Margin="4">
                <CheckBox x:Name="DarkThemeCheck" Content="Тёмная тема" Checked="OnThemeChanged" Unchecked="OnThemeChanged"/>
                <TextBlock Text="Изменение применяется сразу и сохраняется для следующих запусков." Margin="0,4,0,0"
                           Foreground="{StaticResource NeutralBrush}" FontSize="11"/>
            </StackPanel>
        </GroupBox>

        <TextBlock x:Name="OperationStatusText" Grid.Row="6" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="{StaticResource NeutralBrush}" Margin="0,0,0,6" Text="Готово к работе."/>
        <TextBlock x:Name="StatusText" Grid.Row="7" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="{StaticResource NeutralBrush}" Margin="0,0,0,8"/>

        <StackPanel x:Name="ActionBarBottom" Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Width="110" Margin="0,0,8,0" Click="OnSave"/>
            <Button Content="Отмена"    Style="{StaticResource NeutralButton}" Width="110" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
